<!DOCTYPE html>
<html>
<head>
    <title>PixelUltra Store</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Press Start 2P', cursive; background: #f4f4f4; padding: 20px; font-size: 12px; }
        .box { border: 5px solid black; background: white; padding: 20px; margin-bottom: 20px; box-shadow: 8px 8px 0px #888; }
        .grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; }
        .card { border: 4px solid #333; padding: 10px; text-align: center; }
        .card img { width: 100px; image-rendering: pixelated; }
        button { font-family: 'Press Start 2P'; cursor: pointer; background: #ff4757; color: white; border: 3px solid black; padding: 5px; }
        input { font-family: 'Press Start 2P'; padding: 5px; margin: 5px 0; width: 90%; font-size: 10px; }
        h1 { color: #2f3542; border-bottom: 4px solid black; display: inline-block; }
    </style>
</head>
<body>

    <div class="box">
        <h1>PIXELULTRA ADMIN</h1>
        <form action="/add_product" method="post">
            <input type="text" name="name" placeholder="Product Name" required>
            <input type="text" name="price" placeholder="Price (BDT)" required>
            <input type="text" name="img_url" placeholder="Image URL (e.g. https://via.placeholder.com/100)" required>
            <br><button type="submit">UPLOAD PRODUCT</button>
        </form>
    </div>

    <div class="box">
        <h1>STATIONARY SHOP</h1>
        <div class="grid">
            {% for i in range(products|length) %}
            <div class="card">
                <img src="{{ products[i].image }}">
                <p>{{ products[i].name }}</p>
                <p>{{ products[i].price }} BDT</p>
                <a href="/place_order/{{ i }}"><button>ORDER</button></a>
            </div>
            {% endfor %}
        </div>
    </div>

    <div class="box">
        <h1>PENDING ORDERS</h1>
        <ul>
            {% for order in orders %}
            <li>Item: {{ order.item }} - <span style="color:red;">[{{ order.status }}]</span></li>
            {% endfor %}
        </ul>
    </div>

</body>
</html>
  
